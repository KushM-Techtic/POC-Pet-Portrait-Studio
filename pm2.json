{
  "apps": [
    {
      "name": "pet-portrait-backend",
      "cwd": "./backend",
      "script": "python3",
      "args": "-m uvicorn app.main:app --host 0.0.0.0 --port 8003",
      "watch": false,
      "autorestart": true,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "pet-portrait-frontend",
      "cwd": "./frontend",
      "script": "bash",
      "args": "-lc \"npm install && npm run build && npm run preview -- --host 0.0.0.0 --port 5173\"",
      "watch": false,
      "autorestart": true,
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}

