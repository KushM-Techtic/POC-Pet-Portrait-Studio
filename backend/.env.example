APP_ENV=local
APP_PORT=9000

# Shopify Admin API
SHOPIFY_STORE_DOMAIN=techticdemo.myshopify.com
SHOPIFY_API_VERSION=2026-01

# Admin API token (keep secret; don't commit)
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx

# Default tag to filter your POC products
SHOPIFY_POC_TAG=poc-ai-gen

# Metafields (namespace + keys)
SHOPIFY_METAFIELD_NAMESPACE=custom
SHOPIFY_METAFIELD_KEYS_CSV=pet_image,template_image,style_image,pet_name,pet_type

# Gemini / NanoBanana (AI Studio key)
GEMINI_API_KEY=your_key_here
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-image
GEMINI_ASPECT_RATIO=3:4
GEMINI_MAX_RETRIES=4
GEMINI_INITIAL_BACKOFF_S=2.0

# Output storage (served by backend)
OUTPUT_DIR=outputs

# Prompt Python module (must expose get_prompt(has_style_image: bool))
PROMPT_MODULE=prompts.renaissance_v1

# Generate-all tuning
GENERATE_ALL_FIRST=25
GENERATE_ALL_DELAY_MS=800

